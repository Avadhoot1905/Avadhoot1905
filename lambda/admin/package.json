{
  "name": "admin-lambda",
  "version": "1.0.0",
  "description": "Admin Lambda for fetching chat logs from Neon PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "test": "node dist/index.js",
    "dev": "tsx index.ts",
    "package": "npm run build && cd dist && zip -r ../function.zip . && cd ..",
    "deploy:prepare": "npm install --production && npm run build"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.5",
    "express-rate-limit": "^8.2.1",
    "typescript": "^5.7.3"
  }
}
